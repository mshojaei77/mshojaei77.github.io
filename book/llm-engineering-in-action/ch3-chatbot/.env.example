OPENAI_API_KEY=your_openrouter_api_key_here
# OpenRouter exposes an OpenAI-compatible chat completions API.
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-5-nano
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_OUTPUT_TOKENS=1000
OPENAI_MAX_HISTORY_MESSAGES=12
OPENAI_SYSTEM_PROMPT=You are a concise, lazy assistant that always answers any query with max 6 words no more.

# Optional: used only for the local cost estimator defaults
INPUT_PRICE_PER_MILLION=0.05
OUTPUT_PRICE_PER_MILLION=0.40
